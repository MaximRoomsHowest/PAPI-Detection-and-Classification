# Root-level docker-compose env file.
#
# ``docker compose`` automatically reads ``.env`` from the repo root if present.
# Copy this file to ``.env`` and adjust values for your deployment:
#
#   cp .env.example .env
#
# DO NOT COMMIT THE RESULTING .env FILE — it is gitignored.

# ---------------------------------------------------------------------------
# Postgres credentials
# ---------------------------------------------------------------------------
# Used by the postgres service and consumed by the backend's DATABASE_URL.
# Generate a strong password (e.g. ``openssl rand -base64 32``) for any deploy
# beyond local development. Reusing "papi" is fine for local-only runs.
POSTGRES_USER=papi
POSTGRES_PASSWORD=papi

# ---------------------------------------------------------------------------
# Backend
# ---------------------------------------------------------------------------
# ``production`` flips the security floor: the backend refuses to start
# without PAPI_API_KEY being set. Use ``local`` (the default) for dev / CI /
# local docker-compose.
PAPI_ENV=local

# Required when PAPI_ENV=production. Recommended even in local for parity
# with deployed behaviour. Keep this secret; treat it like a password.
PAPI_API_KEY=

# Origins allowed by CORS. Comma-separated or JSON list.
PAPI_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Inference tuning. Bounds: 0.0 <= confidence_threshold <= 1.0.
PAPI_DEVICE=cpu
PAPI_CONFIDENCE_THRESHOLD=0.4
PAPI_MAX_UPLOAD_MB=100
PAPI_MAX_VIDEO_FRAMES=600
PAPI_MAX_VIDEO_SECONDS=30
PAPI_VIDEO_HISTORY_SIZE=5

# ---------------------------------------------------------------------------
# Frontend (build-time)
# ---------------------------------------------------------------------------
# Browser-side backend URL — what the user's machine resolves, not what the
# frontend container resolves. Vite inlines this into the static bundle at
# build time; changing it requires rebuilding the frontend image.
FRONTEND_PAPI_API_URL=http://localhost:8000
