# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
build/
dist/

# Virtual environments
.venv/
venv/
env/

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.ipynb_checkpoints/

# Local assistant/browser tooling
.claude/
.playwright-cli/

# Editor / OS
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# Local secrets
.env
.env.*
!**/.env.example

# Client/raw data and generated ML artifacts
PROJECT1-PAPI/
PAPI_*/
data/raw/
data/work/
data/interim/*.csv
data/interim/*.json
data/labels/*.yaml
data/labels/auto/
data/labels/verified/
data/annotations/
data/datasets/
data/runs/
data/cvat/

# Model binary artifacts — ignored by default everywhere
runs/
*.pt
*.onnx
*.engine
*.torchscript
*.safetensors
models/**/*.pt
models/**/*.onnx
models/**/*.engine
models/**/*.torchscript
models/**/*.safetensors

# Whitelist: committed model artifacts at their canonical paths
!models/base/*.pt
!models/base/*.onnx
!models/serving/*.pt
!models/serving/*.onnx
!models/runs/
!models/runs/**

# Frontend/backend generated outputs
apps/frontend/node_modules/
apps/frontend/dist/
apps/backend/storage/

# Generated CVAT/export archives and videos
*.zip
*.mp4
*.avi
!test_videos/*.mp4
!models/runs/**/*.mp4
