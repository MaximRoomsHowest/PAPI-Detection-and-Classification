# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
build/
dist/

# Virtual environments
.venv/
venv/
env/

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.ipynb_checkpoints/

# Local assistant/browser tooling
.claude/
.playwright-cli/

# Editor / OS
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# Local secrets
.env
.env.*
!**/.env.example

# Client/raw data and generated ML artifacts
PROJECT1-PAPI/
PAPI_*/
data/raw/
data/work/
data/interim/*.csv
data/interim/*.json
data/labels/*.yaml
data/labels/auto/
data/labels/verified/
data/annotations/
data/datasets/
data/runs/
data/cvat/

# Model binary artifacts — ignored by default everywhere
runs/
*.pt
*.onnx
*.engine
*.torchscript
*.safetensors
models/**/*.pt
models/**/*.onnx
models/**/*.engine
models/**/*.torchscript
models/**/*.safetensors

# Whitelist: committed model artifacts at their canonical paths
!models/base/*.pt
!models/base/*.onnx
!models/serving/*.pt
!models/serving/*.onnx
!models/runs/
!models/runs/**

# Frontend/backend generated outputs
apps/frontend/node_modules/
apps/frontend/dist/
apps/backend/storage/

# Local trial folders created outside the canonical apps/* workspace.
# Keep source changes in apps/frontend and apps/backend instead.
/frontend/
/backend/

# Generated CVAT/export archives and videos
*.zip
*.mp4
*.avi
!test_videos/*.mp4
!models/runs/**/*.mp4

# --------------------------------------------------------------------------
# Audit / review artefacts (added 2026-05-27 after the v1.1 audit follow-up).
# These are regenerated on demand by visual-review and smoke-test workflows;
# they have no business in the tracked tree.
# --------------------------------------------------------------------------

# Chrome-MCP screenshots produced when running visual reviews against a
# local stack (audit SMOKE-MIN-2). Re-created the next time the same flow
# runs; no commit value.
audit-screenshots/

# Local docker compose overrides. Convention is that anyone needing a
# machine-specific tweak drops it here without modifying the canonical
# docker-compose.yml. The Tier-A CORS workaround that briefly lived here
# is no longer needed (SMOKE-CRIT-2 is fixed), but the convention stays.
docker-compose.override.yml
