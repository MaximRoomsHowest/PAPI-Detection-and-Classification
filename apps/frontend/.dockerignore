Thumbs.db

# Project meta we don't need at build time
README.md
Dockerfile
.dockerignore
# NOTE: nginx.conf MUST stay in the build context — the multi-stage Dockerfile
# copies it into /etc/nginx/conf.d/default.conf in the `serve` stage. Excluding
# it breaks `docker compose up --build` (see audit SMOKE-CRIT-1).
