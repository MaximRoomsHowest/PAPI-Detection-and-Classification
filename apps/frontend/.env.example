VITE_PAPI_API_URL=http://127.0.0.1:8000

# Optional: API key the frontend sends as X-API-Key. Note that anything
# inlined into the bundle is visible to anyone who downloads the page, so
# this is not a real security boundary — see audit F-CRIT-3.
# VITE_PAPI_API_KEY=

# Optional client-side upload + timeout guards. Defaults match the backend's
# server-side limits so users see fast feedback instead of waiting for a 413
# (audit F-MAJ-8).
# VITE_PAPI_MAX_UPLOAD_MB=100
# VITE_PAPI_REQUEST_TIMEOUT_MS=60000
